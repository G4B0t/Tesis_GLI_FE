# API Configuration
VITE_REACT_APP_BACKEND_URL=http://127.0.0.1:8008
VITE_REACT_APP_API_DEBUG=true

# Docker Configuration
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# Port Configuration
DEV_PORT=5173
PROD_PORT=80

# Cognito SSO Configuration
VITE_REACT_APP_COGNITO_DOMAIN=https://your-cognito-domain.auth.region.amazoncognito.com
VITE_REACT_APP_COGNITO_CLIENT_ID=your_cognito_client_id
VITE_REACT_APP_COGNITO_REDIRECT_URI=http://localhost:8080/v2/authentication/sso/callback/

# Optional license keys
VITE_REACT_APP_MUI_PRO_LICENCE_KEY=
